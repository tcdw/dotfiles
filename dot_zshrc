[ -f "$HOME/.shellenv" ] && source "$HOME/.shellenv"

eval "$(starship init zsh)"

# direnv
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

export GPG_TTY="$(tty)"

ulimit -n 65536

# Timidity configuration to use GeneralUser-GS soundfont by default
export TIMIDITY_CONFIG="$HOME/.timidity/timidity.cfg"
alias timidity='timidity -c ~/.timidity/timidity.cfg'

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
